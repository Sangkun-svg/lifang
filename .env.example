SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Absolute production site URL used for crawler-facing metadata such as favicon.
# Example: https://www.example.com
NEXT_PUBLIC_SITE_URL=

# Comma-separated fallback allowlist for admin login.
# Supabase users with app_metadata.role or user_metadata.role set to "admin"
# are also accepted.
ADMIN_ALLOWED_EMAILS=

# Set true only when local development should accept any non-empty login.
LOCAL_AUTH_BYPASS=false

# Unmatched uploaded sheets are hard-deleted after this many days.
UNMATCHED_SHEET_RETENTION_DAYS=14

# Used by Vercel Cron to call /api/admin/sheets/cleanup.
CRON_SECRET=

# Server-only Slack error notifications. Bot token needs chat:write scope.
SLACK_BOT_TOKEN=
SLACK_ERROR_CHANNEL_ID=

# Production-level E2E test accounts. Use real Supabase accounts:
# - admin account must have role=admin or be listed in ADMIN_ALLOWED_EMAILS.
# - user account must not have admin role.
LIFANG_E2E_ADMIN_EMAIL=
LIFANG_E2E_ADMIN_PASSWORD=
LIFANG_E2E_USER_EMAIL=
LIFANG_E2E_USER_PASSWORD=
